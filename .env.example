# PostgreSQL
POSTGRES_DB=the_shop
POSTGRES_USER=the_shop_user
POSTGRES_PASSWORD=changeme

# pgAdmin
PGADMIN_EMAIL=your@gmail.com
PGADMIN_PASSWORD=changeme

# JWT — secret de signature HS256, >= 32 caractères (256 bits)
# Génère-le avec : openssl rand -base64 48
JWT_SECRET=change-me-to-a-32-chars-minimum-secret
